{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Projectclownfish cluster job",
  "type": "object",
  "required": ["repo", "cluster_id", "mode", "allowed_actions"],
  "additionalProperties": true,
  "properties": {
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "cluster_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": ["plan", "execute", "autonomous"]
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "enum": ["comment", "label", "close", "merge", "fix", "raise_pr"]
      }
    },
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "require_human_for": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "canonical": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^#?[0-9]+$"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^#?[0-9]+$"
      }
    },
    "cluster_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allow_instant_close": {
      "type": "boolean"
    },
    "allow_low_signal_pr_close": {
      "type": "boolean"
    },
    "allow_fix_pr": {
      "type": "boolean"
    },
    "allow_merge": {
      "type": "boolean"
    },
    "allow_post_merge_close": {
      "type": "boolean"
    },
    "security_policy": {
      "type": "string",
      "enum": ["central_security_only"]
    },
    "security_sensitive": {
      "type": "boolean",
      "const": false
    },
    "canonical_hint": {
      "type": "string"
    },
    "target_checkout": {
      "type": "string"
    },
    "triage_policy": {
      "type": "string",
      "enum": ["low_signal_prs"]
    },
    "notes": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "clawsweeper_report_repo": {
      "type": "string"
    },
    "clawsweeper_report_path": {
      "type": "string"
    }
  }
}
